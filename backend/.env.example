NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/project_management
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=1h
JWT_ISSUER=project-management-api
CLIENT_ORIGIN=http://localhost:5173
# Optional workaround when the local DNS provider blocks MongoDB SRV lookups.
# DNS_SERVERS=8.8.8.8,1.1.1.1
REDIS_URL=redis://127.0.0.1:6379
SEED_USER_NAME=Demo Owner
SEED_USER_EMAIL=owner@example.com
SEED_USER_PASSWORD=ChangeMe123!
